{
  "name": "@wave-av/core",
  "version": "0.1.0",
  "description": "WAVE SDK core — gateway client, auth, shared types. The base every @wave-av/<product> package depends on.",  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist/**/*.js", "dist/**/*.mjs", "dist/**/*.d.ts", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean && tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "license": "MIT",
  "author": "WAVE Online, LLC <sdk@wave.online>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wave-av/sdks.git",
    "directory": "sdk-typescript/packages/core"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "engines": { "node": ">=18.0.0" },
  "peerDependencies": {
    "zod": "^3.22.0",
    "@opentelemetry/api": "^1.7.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": { "optional": true }
  },
  "dependencies": {
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "zod": "3.25.76"
  }
}
