{
  "name": "@wave-av/mcp-server",
  "version": "0.1.8",
  "description": "WAVE MCP server — streaming API tools + a generic gateway-call escape hatch for Claude Code, Cursor, Windsurf, and other AI coding assistants",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "wave-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wave",
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "windsurf",
    "ai",
    "streaming",
    "video",
    "tools",
    "copilot"
  ],
  "author": "WAVE Online, LLC <sdk@wave.online>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wave-av/sdks.git",
    "directory": "sdk-typescript/packages/mcp-server"
  },
  "homepage": "https://docs.wave.online/mcp",
  "bugs": {
    "url": "https://github.com/wave-av/sdks/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0"
  }
}
