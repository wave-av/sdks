{
  "name": "@wave-av/clips",
  "version": "0.1.0",
  "description": "WAVE Clips client — typed access to the clip-engine product through the WAVE gateway. Entitlement enforced server-side (401/403).",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean && tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "license": "Apache-2.0",
  "author": "WAVE Online, LLC <sdk@wave.online>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wave-av/sdks.git",
    "directory": "sdk-typescript/packages/clips"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "dependencies": {
    "@wave-av/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "zod": "3.25.76"
  },
  "sideEffects": false
}
