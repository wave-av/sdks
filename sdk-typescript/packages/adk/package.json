{
  "name": "@wave-av/adk",
  "version": "1.0.14",
  "description": "WAVE Agent Developer Kit \u2014 build AI video agents with 10 MCP tools, 5 templates, and framework adapters for Mastra, LangGraph, LiveKit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "require": "./dist/tools/index.cjs",
      "default": "./dist/tools/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js",
      "require": "./dist/agents/index.cjs",
      "default": "./dist/agents/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs",
      "default": "./dist/adapters/index.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "import": "./dist/templates/index.js",
      "require": "./dist/templates/index.cjs",
      "default": "./dist/templates/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs",
      "default": "./dist/types.js"
    }
  },
  "typesVersions": {
    "*": {
      "tools": [
        "./dist/tools/index.d.ts"
      ],
      "agents": [
        "./dist/agents/index.d.ts"
      ],
      "adapters": [
        "./dist/adapters/index.d.ts"
      ],
      "templates": [
        "./dist/templates/index.d.ts"
      ],
      "types": [
        "./dist/types.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/tools/index.ts src/agents/index.ts src/adapters/index.ts src/templates/index.ts src/types.ts --format esm,cjs && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wave",
    "adk",
    "agent",
    "video",
    "streaming",
    "mcp",
    "ai"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "ERROR-CODES.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wave-av/sdks.git",
    "directory": "sdk-typescript/packages/adk"
  },
  "bugs": {
    "url": "https://github.com/wave-av/sdks/issues"
  },
  "homepage": "https://wave.online/developers/adk",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.4"
  },
  "author": "WAVE Online, LLC <sdk@wave.online>"
}
