{
  "name": "@wave-av/workflow-sdk",
  "version": "1.0.6",
  "description": "WAVE Workflow SDK \u2014 build and execute multi-phase workflows with real-time events, checkpoints, and retry logic",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/types.ts src/client.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/types.ts src/client.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wave",
    "workflow",
    "automation",
    "orchestration",
    "streaming",
    "pipeline",
    "jobs",
    "agent",
    "video",
    "sdk"
  ],
  "author": "WAVE Online, LLC <sdk@wave.online>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wave-av/sdks.git",
    "directory": "sdk-typescript/packages/workflow-sdk"
  },
  "homepage": "https://docs.wave.online/sdk/workflows",
  "bugs": {
    "url": "https://github.com/wave-av/sdks/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "zod": "3.25.76"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
